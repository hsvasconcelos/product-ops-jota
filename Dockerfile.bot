FROM python:3.12-slim
WORKDIR /app

# deps primeiro (cache de camada): o projeto + o que o bot adiciona
COPY pyproject.toml ./
COPY src ./src
RUN pip install --no-cache-dir -e . "fastapi" "uvicorn[standard]" "openai" "httpx"

COPY . .
CMD ["uvicorn", "apps.whatsapp_bot:app", "--host", "0.0.0.0", "--port", "8000"]
